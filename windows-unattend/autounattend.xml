<?xml version="1.0" encoding="utf-8"?>
<!--
  autounattend.xml - habilita e inicia o OpenSSH Server durante a instalação do Windows,
  pra já dar pra conectar remoto (remote/remote.ps1 ou remote/remote.sh) assim que o
  Windows terminar de instalar, sem precisar tocar na máquina.

  NÃO mexe em mais nada da instalação (sem resposta automática de disco, product key,
  conta de usuário, etc.) - o Setup continua mostrando as telas normais, só roda esse
  comando extra durante o pass "specialize" (depois de copiar os arquivos, antes do OOBE).

  Como usar:
    1. Copie este arquivo pro RAIZ do pendrive/mídia de instalação do Windows, com o
       nome exato "autounattend.xml".
    2. O Windows Setup detecta e aplica sozinho durante a instalação.
    3. TESTE numa máquina de sobra antes de usar em produção - qualquer erro de sintaxe
       nesse arquivo pode fazer o Setup ignorá-lo silenciosamente (o que não quebra a
       instalação, só não habilita o SSH) ou, em casos raros, travar o Setup.
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend">
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Description>Habilita e inicia o OpenSSH Server (para acesso remoto do toolkit)</Description>
          <Path>powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0; Set-Service -Name sshd -StartupType Automatic; Start-Service sshd; if (-not (Get-NetFirewallRule -Name 'OpenSSH-Server-In-TCP' -ErrorAction SilentlyContinue)) { New-NetFirewallRule -Name 'OpenSSH-Server-In-TCP' -DisplayName 'OpenSSH Server (sshd)' -Enabled True -Direction Inbound -Protocol TCP -Action Allow -LocalPort 22 }"</Path>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>
  </settings>
</unattend>
